{
  "name": "multiplayer-number-guesser",
  "version": "1.0.0",
  "description": "Real-time multiplayer number guessing game with WebSocket support",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:e2e": "node scripts/start-e2e.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" --names \"server,vite\" --prefix-colors \"cyan,magenta\"",
    "dev:server": "nodemon server.js",
    "dev:client": "node scripts/start-dev-client.js",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "production": "pm2 start server.js --name multiplayer-game",
    "stop": "pm2 stop multiplayer-game",
    "lint": "eslint . --ext .js,.cjs --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.cjs --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage --coverageReporters=text-summary --coverageReporters=lcov --coverageReporters=json-summary",
    "test:unit": "jest tests/services",
    "test:integration": "jest tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:ci": "npm run lint && npm run format:check && npm run test:coverage && npm run build && npm run test:e2e"
  },
  "keywords": [
    "multiplayer",
    "game",
    "websocket",
    "nodejs",
    "realtime"
  ],
  "author": "Blessan Corley A",
  "license": "MIT",
  "dependencies": {
    "@upstash/redis": "^1.36.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.9.2",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "pg-mem": "^3.0.14",
    "pm2": "^5.3.0",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Blessan-Corley/Guess-the-Number-Multiplayer.git"
  }
}
