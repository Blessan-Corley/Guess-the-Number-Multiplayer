# ─── LOCAL DEVELOPMENT ───────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For Render (or any production host) set these vars in the host dashboard
# — do NOT commit .env.  See the RENDER PRODUCTION section at the bottom.

NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
# On Render, APP_BASE_URL can be omitted if RENDER_EXTERNAL_URL is available.

# Game store — "memory" (default) or "redis" (Upstash / ioredis)
STORE_MODE=memory
SESSION_TTL_SECONDS=3600
CLEANUP_INTERVAL=300000
RECONNECT_GRACE_PERIOD_MS=120000
REDIS_KEY_PREFIX=number-guesser:development:

# Upstash REST (serverless Redis — preferred for Render/Railway/Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Standard ioredis (self-hosted Redis / Redis Cloud / Render Redis add-on)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL — optional, enables profiles + leaderboard
# Use sslmode=require for Neon / Supabase / any hosted provider.
# Do NOT add channel_binding=require — the pg npm package does not support it.
DATABASE_URL=
# Common aliases also supported by the app:
# POSTGRES_URL=
# POSTGRESQL_URL=
DATABASE_POOL_MAX=10
DATABASE_SSL_REJECT_UNAUTHORIZED=true

CORS_ORIGINS=http://localhost:3000
SOCKET_CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

PROFILE_MATCH_HISTORY_LIMIT=20
LEADERBOARD_LIMIT=20

APP_VERSION=1.0.0
COMMIT_SHA=local

# ─── RENDER PRODUCTION (set in Render dashboard, not in this file) ───────────
#
# NODE_ENV=production
# PORT=10000                          ← Render assigns this automatically
# APP_BASE_URL=https://your-app.onrender.com
#
# STORE_MODE=redis
# REDIS_KEY_PREFIX=number-guesser:production:   ← must differ from dev prefix
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
# REDIS_URL=redis://default:password@host:6379  ← also enables redis automatically
#
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
#
# CORS_ORIGINS=https://your-app.onrender.com
# SOCKET_CORS_ORIGINS=https://your-app.onrender.com
# TRUST_PROXY=1                       ← Render sits behind 1 proxy hop
#
# LOG_LEVEL=info
# APP_VERSION=2.0.0
# COMMIT_SHA=<set by CI>
